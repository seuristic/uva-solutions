CompileFlags:
  Add:
    - "-std=c++20"
    - "-nostdinc++"
    - "-I/opt/homebrew/Cellar/gcc/15.2.0/include/c++/15"
    - "-I/opt/homebrew/Cellar/gcc/15.2.0/include/c++/15/aarch64-apple-darwin24"
    - "-I/opt/homebrew/Cellar/gcc/15.2.0/include/c++/15/backward"
    - "-isysroot"
    - "/Library/Developer/CommandLineTools/SDKs/MacOSX26.sdk"
    - "-Wno-invalid-constexpr"
    - "-Wno-deprecated-builtins"
    - "-Wno-ignored-attributes"
    - "-Wno-inline-namespace-reopened-noninline"
    - "-Wno-keyword-compat"
    - "-Wno-unknown-attributes"
    - "-Wno-unknown-warning-option"
    - "-Wno-user-defined-literals"
    - "-Wno-deprecated-volatile"
    - "-Wno-inconsistent-missing-override"
    - "-Wno-switch"
